{
  "name": "Supplier Search Agent",

  "dockerComposeFile": "docker-compose.yml",

  "service": "app",
  "workspaceFolder": "/workspace",

  "forwardPorts": [8080, 5050, 5432, 11434],

  "portsAttributes": {
    "8080": { "label": "SearXNG" },
    "5050": { "label": "pgAdmin", "onAutoForward": "openBrowser" },
    "5432": { "label": "Postgres" },
    "11434": { "label": "Ollama" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "postCreateCommand": "pip install -r requirements.txt",

  "remoteUser": "root"
}